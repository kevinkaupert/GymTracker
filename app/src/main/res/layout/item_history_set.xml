<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView
        android:id="@+id/exerciseName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Bankdrücken"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/setDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Satz 1: 10 x 80kg"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="@color/secondary" />

    <ImageButton
        android:id="@+id/editSetButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Bearbeiten"
        android:src="@android:drawable/ic_menu_edit"
        android:tint="@color/primary" />

    <ImageButton
        android:id="@+id/deleteSetButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Löschen"
        android:src="@android:drawable/ic_menu_delete"
        android:tint="@color/error" />

</LinearLayout>
